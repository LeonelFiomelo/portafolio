---
import ItemAboutMe from "../items/ItemAboutMe.astro";
import HeaderSection from "../headers/HeaderSection";
import ItemCharacteristic from "../items/ItemCharacteristic.astro";
import {
    MonitorSvg,
    BackendSvg,
    WorldSvg,
    BookSvg,
    StarSvg,
    RocketSvg,
    UsersSvg,
    ThunderSvg,
    FireSvg,
    UserSvg,
} from "../../svgs";
---

<section class="w-full py-12 px-4" id="about">
    <div class="flex flex-col max-w-7xl mx-auto gap-4">
        <HeaderSection label="Conóceme mejor" title="Sobre mí">
            <UserSvg />
        </HeaderSection>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <article class="space-y-4 my-auto text-lg text-gray-200">
                <p>
                    Ingeniero de Sistemas enfocado en la creación de productos
                    web
                    <span class="text-red-400"
                        >escalables y de alto rendimiento.</span
                    >. Especializado en el ecosistema React/Next.js, con un
                    fuerte background en .NET, lo que me permite tener una
                    <span class="text-pink-400">visión arquitectónica</span>
                    integral (Full Stack) de las aplicaciones.
                </p>
                <p>
                    Me motiva resolver problemas complejos de negocio mediante
                    código limpio, arquitecturas mantenibles y una excelente
                    experiencia de usuario.
                </p>
                <div class="flex flex-col w-full gap-4 mt-8">
                    <h4 class="flex items-center gap-2">
                        <StarSvg className="text-red-400" /> Características Personales
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <ItemCharacteristic text="Aprendizaje Continuo">
                            <ThunderSvg slot="icon" className="text-red-400" />
                        </ItemCharacteristic>
                        <ItemCharacteristic text="Trabajo en Equipo">
                            <UsersSvg slot="icon" className="text-pink-400" />
                        </ItemCharacteristic>
                        <ItemCharacteristic text="Orientado a Resultados">
                            <FireSvg slot="icon" className="text-purple-500" />
                        </ItemCharacteristic>
                        <ItemCharacteristic text="Innovación">
                            <RocketSvg slot="icon" className="text-amber-500" />
                        </ItemCharacteristic>
                    </div>
                </div>
            </article>
            <article class="grid grid-cols-2 gap-4">
                <ItemAboutMe
                    title="Frontend"
                    subtitle="Arquitectura & UI/UX"
                    color="red"
                >
                    <MonitorSvg
                        slot="icon"
                        size={40}
                        className="text-red-400"
                    />
                </ItemAboutMe>
                <ItemAboutMe
                    title="Backend"
                    subtitle="APIs Resilientes"
                    color="pink"
                >
                    <BackendSvg
                        slot="icon"
                        size={40}
                        className="text-pink-400"
                    />
                </ItemAboutMe>
                <ItemAboutMe
                    title="Deployment"
                    subtitle="CI/CD & Cloud"
                    color="rose"
                >
                    <WorldSvg slot="icon" size={40} className="text-rose-400" />
                </ItemAboutMe>
                <ItemAboutMe
                    title="Aprendizaje"
                    subtitle="Mejora Continua"
                    color="amber"
                >
                    <BookSvg slot="icon" size={40} className="text-amber-500" />
                </ItemAboutMe>
            </article>
        </div>
    </div>
</section>
